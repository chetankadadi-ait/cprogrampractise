1)Write a program to find frequency of each character in a string. using pointer

#include<stdio.h>
#include<string.h>
int main()
{
 char str[100];
 char *ptr;
 int i;
 int freq[256]={0};

 printf("enter a string\n");
 fgets(str,sizeof(str),stdin);
 ptr=str;
 while (*ptr!='\0'){
    if (*ptr!='\n'){
        freq[(int)*ptr]++;

    }
    ptr++;
 }
 printf("\nfrequency of character\n");
 for (int i=0;i<256;i++){
        if(freq[i]!=0)
           {
        printf("\n %c=%d\n",i,freq[i]);

 }
 }
 return 0;
}
2)Write a program to sort characters of a string using pointers.

#include <stdio.h>
#include <string.h>

int main()
{
    char str[100];
    char *ptr1, *ptr2;
    char temp;

    printf("Enter a string:\n");
    fgets(str, sizeof(str), stdin);

    // Remove newline
    str[strcspn(str, "\n")] = '\0';

    // Sorting using pointers (Bubble Sort)
    for (ptr1 = str; *ptr1 != '\0'; ptr1++) {
        for (ptr2 = ptr1 + 1; *ptr2 != '\0'; ptr2++) {
            if (*ptr1 > *ptr2) {
                temp = *ptr1;
                *ptr1 = *ptr2;
                *ptr2 = temp;
            }
        }
    }

    printf("Sorted string: %s\n", str);

    return 0;
}
