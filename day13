2)Count frequency of each character

#include <stdio.h>
#include <string.h>
int main(){
 char name[100];
int freq[256]={0};
printf("enter a string\n");
fgets(name,sizeof(name),stdin);

 int length=strlen(name);
for (int i=0;i<length;i++){
    freq[name[i]]++;
}
printf("\n character frequency\n");
for (int i=0;i<256;i++){
    if (freq[i]!= 0&&freq[i]!='\n'){
        printf("'%c' = %d\n", i, freq[i]);
    }
}
return 0;
}
1)Remove spaces from string
#include<stdio.h>
#include<string.h>

int main()
{
    char arr[20];
    int i, j = 0;   

    printf("enter a string\n");
    fgets(arr, sizeof(arr), stdin);

    int len = strlen(arr);

    for (i = 0; i < len; i++) {
        if (arr[i] != ' ' && arr[i] != '\n') {
            arr[j] = arr[i];
            j++;
        }
    }

    arr[j] = '\0';   

    printf("character without space = %s", arr);

    return 0;
}

