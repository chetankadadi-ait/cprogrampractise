1)Check if two strings are anagrams
#include <stdio.h>
#include <string.h>

int main()
{
    char str1[20] = "chetan";
    char str2[20] = "tanche";

    // Sort both strings
    strlwr(str1); // optional: for case-insensitive
    strlwr(str2);

    int n1 = strlen(str1);
    int n2 = strlen(str2);

    if (n1 != n2) {
        printf("Not anagrams\n");
        return 0;
    }

    // Bubble sort both strings
    for(int i = 0; i < n1-1; i++) {
        for(int j = i+1; j < n1; j++) {
            if(str1[i] > str1[j]) {
                char temp = str1[i];
                str1[i] = str1[j];
                str1[j] = temp;
            }
            if(str2[i] > str2[j]) {
                char temp = str2[i];
                str2[i] = str2[j];
                str2[j] = temp;
            }
        }
    }

    // Compare sorted strings
    if(strcmp(str1, str2) == 0)
        printf("Strings are anagrams\n");
    else
        printf("Not anagrams\n");

    return 0;
}
