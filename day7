2)Remove duplicates from array
#include <stdio.h>

int main()
{
    int arr[7];
    int i, j, n = 7;

    printf("Enter 7 elements:\n");
    for(i = 0; i < n; i++){
        scanf("%d", &arr[i]);
    }

    // Sorting (Bubble Sort)
    for(i = 0; i < n - 1; i++){
        for(j = 0; j < n - i - 1; j++){
            if(arr[j] > arr[j + 1]){
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }

    // Print without duplicates
    printf("Array without duplicates:\n");
    for(i = 0; i < n; i++){
        if(i == 0 || arr[i] != arr[i - 1]){
            printf("%d ", arr[i]);
        }
    }

    return 0;
}

