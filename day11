3)Word Counter (Combines Strings, Loops & Logic)
#include <stdio.h>
#include <string.h>

int main()
{
    char str[100];
    int i = 0;
    int count = 1;

    printf("Enter a string:\n");
    fgets(str, sizeof(str), stdin);

    // Handle empty input
    if (str[0] == '\n') {
        count = 0;
    }

    while (str[i] != '\0') {

        if (str[i] == ' ' && str[i+1] != '\n' && str[i+1] != '\0') {
            count++;
        }
        i++;
    }

    printf("Total = %d\n", count);

    return 0;
}
