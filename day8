3)finding missing number
#include <stdio.h>
int main() {
    int arr[4], i;
    int n = 5;   
    int sum = 0, total, missing;

    printf("Enter 4 elements:\n");
    for(i = 0; i < 4; i++) {
        scanf("%d", &arr[i]);
        sum = sum + arr[i];
    }

    
    total = n * (n + 1) / 2;

    
    missing = total - sum;

    printf("Missing number is: %d", missing);

    return 0;
}
