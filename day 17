1)Write a program to find frequency of each character in a string. using pointer
#include <stdio.h>

int main()
{
    char str[100];
    int freq[256] = {0};  
    char *ptr;

    printf("Enter a string: ");
    fgets(str, sizeof(str), stdin);

    ptr = str;

    
    while (*ptr != '\0')
    {
        if (*ptr != '\n')   
        {
            freq[(int)*ptr]++;
        }
        ptr++;
    }

    
    printf("\nCharacter Frequency:\n");
    for (int i = 0; i < 256; i++)
    {
        if (freq[i] != 0)
        {
            printf("%c = %d\n", i, freq[i]);
        }
    }

    return 0;
}
