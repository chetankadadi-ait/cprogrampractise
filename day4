1)Write a program to demonstrate pointer initialization and usage

#include <stdio.h>

int main()
{
    int a = 10;        // normal variable
    int *ptr;          // pointer declaration

    ptr = &a;          // pointer initialization (stores address of a)

    // Printing values
    printf("Value of a: %d\n", a);
    printf("Address of a: %p\n", &a);

    printf("Pointer ptr stores address: %p\n", ptr);
    printf("Value using pointer (*ptr): %d\n", *ptr);

    // Modifying value using pointer
    *ptr = 20;

    printf("New value of a after modification: %d\n", a);

    return 0;
}
