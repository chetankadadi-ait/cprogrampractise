3)Write a program to concatenate two strings without using library functions with help of pointer
#include <stdio.h>

int main()
{
    char str1[100] = "chetan ";
    char str2[] = "kumar";

    char *ptr1 = str1;
    char *ptr2 = str2;

    // Move ptr1 to end of str1
    while (*ptr1 != '\0')
    {
        ptr1++;
    }

    // Copy str2 to end of str1
    while (*ptr2 != '\0')
    {
        *ptr1 = *ptr2;
        ptr1++;
        ptr2++;
    }

    // Add null character at end
    *ptr1 = '\0';

    printf("Concatenated string: %s\n", str1);

    return 0;
}




