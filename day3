#include<stdio.h>
#include<ctype.h>
#include<string.h>

int main()
{
    char arr[50];
    int vowels = 0, consonants = 0, spaces = 0;
    int i;

    printf("Enter a string:\n");
    fgets(arr, sizeof(arr), stdin);   // to read full sentence

    for(i = 0; arr[i] != '\0'; i++)
    {
        if(isalpha(arr[i]))
        {
            char ch = tolower(arr[i]);

            if(ch=='a' || ch=='e' || ch=='i' || ch=='o' || ch=='u')
                vowels++;
            else
                consonants++;
        }
        else if(isspace(arr[i]))
        {
            spaces++;
        }
    }

    printf("Vowels = %d\n", vowels);
    printf("Consonants = %d\n", consonants);
    printf("Spaces = %d\n", spaces);

    return 0;
}
