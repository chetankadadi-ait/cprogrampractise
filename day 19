//2)Write a program to remove duplicate characters from a string.
#include <stdio.h>
#include <string.h>

int main()
{
    char str[] = "programming";
    int i, j, k;
    int len = strlen(str);

    for(i = 0; i < len; i++)
    {
        for(j = i + 1; j < len; j++)
        {
            if(str[i] == str[j])
            {
                // shift characters left
                for(k = j; k < len; k++)
                {
                    str[k] = str[k + 1];
                }
                len--;
                j--; // recheck this index
            }
        }
    }

    printf("String after removing duplicates: %s", str);

    return 0;
}
