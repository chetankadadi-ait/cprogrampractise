1)Compound Interest using for loop


#include <stdio.h>
#include <math.h>

int main() {
    double p = 1000.00;
    double r = 0.05;
    double a;
    int n;

    for (n = 1; n <= 10; n++) {
        a = p * pow((1 + r), n);
        printf("%d %.2lf\n", n, a);
    }

    return 0;
}

