#include <stdio.h>
#include <stdlib.h>
int main() {
    int day;
    printf("Enter a number between 1-7: ");
    scanf("%d", &day);

    switch(day) {
        case 1: printf("mond\n"); break;
        case 2: printf("tues\n"); break;
        case 3: printf("thur\n"); break;
        case 4: printf("wedn\n"); break;
        case 5: printf("frie\n"); break;
        case 6: printf("sund\n"); break;
        case 7: printf("sata\n"); break;
        default: printf("invalid day\n"); break;
    }

    return 0;
}
