3)Write a program to reverse a string using pointers.
#include<stdio.h>
#include<stdlib.h>
#include<string.h>
int main()
{
    char str[20];
    int i=0;
    char *start,*end,temp;
    printf("enter a string\n");
    fgets(str,sizeof(str),stdin);
    str[strcspn(str, "\n")] = '\0';
    start=str;
    end=str+strlen(str)-1;
    while(start<end){
        temp=*start;
        *start=*end;
        *end=temp;
    start++;
    end--;
    }
    printf("reverse string=%s",str);
    return 0;

}
 
