1) String Length using Pointer Arithmetic (Combines Pointers & Strings)

#include<stdio.h>
int main()
{
    char letter[]="cprogram";
    char *ptr=letter;
    while(*ptr!='\0'){
        *ptr++;
    }
    int length=ptr-letter;

    printf("length of %s = %d\n ",letter,length);
    return 0;

}
