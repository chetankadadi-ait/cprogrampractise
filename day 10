8)Q4. Case Converter without Library
Write a C program that:
- Reads a letter from the user
- If uppercase converts to lowercase
- If lowercase converts to uppercase
- If not a letter prints error message
- Do NOT use toupper() or tolower()

Expected Output:
Enter a letter: H
You entered Uppercase  : H
Converted to Lowercase : h
#include <stdio.h>

int main()
{
    char ch;

    printf("Enter an alphabet: ");
    ch = getchar();

    if (ch >= 'A' && ch <= 'Z')
    {
        printf("You entered Uppercase  : %c\n", ch);
        printf("Converted to Lowercase : %c\n", ch + 32);
    }
    else if (ch >= 'a' && ch <= 'z')
    {
        printf("You entered Lowercase  : %c\n", ch);
        printf("Converted to Uppercase : %c\n", ch - 32);
    }
    else
    {
        printf("Error: Not an alphabet letter.\n");
    }

    return 0;
}
