1) Program : Declaring and Printing Strings
#include <stdio.h>

int main() {

    char name[] = "Hello";

    // print as string
    printf("String     : %s\n", name);

    // print length manually
    int len = 0;
    while (name[len] != '\0') {
        len++;
    }
    printf("Length     : %d\n", len);

    // print each character one by one
    printf("Characters : ");
    for (int i = 0; name[i] != '\0'; i++) {
        printf("%c ", name[i]);
    }
    printf("\n");

    return 0;
}
