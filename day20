6)// Program : strcmp()
#include <stdio.h>
#include <string.h>

int main() {

    char str1[50], str2[50];

    printf("Enter first string  : ");
    fgets(str1, sizeof(str1), stdin);
    str1[strlen(str1) - 1] = '\0';

    printf("Enter second string : ");
    fgets(str2, sizeof(str2), stdin);
    str2[strlen(str2) - 1] = '\0';

    int result = strcmp(str1, str2);

    printf("\nComparing \"%s\" and \"%s\"\n", str1, str2);

    if (result == 0)
        printf("Result : Both strings are EQUAL\n");
    else if (result < 0)
        printf("Result : \"%s\" is LESS than \"%s\"\n", str1, str2);
    else
        printf("Result : \"%s\" is GREATER than \"%s\"\n", str1, str2);

    printf("strcmp returned : %d\n", result);

    return 0;
}
