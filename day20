10) Count Letters Digits Spaces in a String
Write a C program that:
- Reads a sentence from the user
- Loops through each character
- Counts letters, digits, spaces and other characters separately
- Prints a full report
Requirements: Use fgets(), for loop with != '\0', isalpha() isdigit() isspace() from ctype.h

Expected Output:
Enter a sentence: Hello World 123!
String  : Hello World 123!
Length  : 16
Letters : 10
Digits  : 3
Spaces  : 2
Others  : 1
#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main()
{
    char str[100];
    int letters = 0, digits = 0, spaces = 0, others = 0;
    int i;

    printf("Enter a sentence: ");
    fgets(str, sizeof(str), stdin);

    // Remove newline character added by fgets
    str[strlen(str) - 1] = '\0';

    for(i = 0; str[i] != '\0'; i++)
    {
        if(isalpha(str[i]))
            letters++;
        else if(isdigit(str[i]))
            digits++;
        else if(isspace(str[i]))
            spaces++;
        else
            others++;
    }

    printf("\nString  : %s\n", str);
    printf("Length  : %lu\n", strlen(str));
    printf("Letters : %d\n", letters);
    printf("Digits  : %d\n", digits);
    printf("Spaces  : %d\n", spaces);
    printf("Others  : %d\n", others);

    return 0;

}
11) Password Checker using strcmp
Write a C program that:
- Has a fixed password stored in the program
- Gives the user 3 attempts to enter the correct password
- Uses strcmp() to check if input matches
- Prints Access Granted if correct, Access Denied after 3 wrong attempts
Requirements: Use fgets(), strcmp(), while loop, remove '\n'

Expected Output (correct on 3rd attempt):
Enter password (attempt 1/3): wrong
Wrong password!
Enter password (attempt 2/3): wrong
Wrong password!
Enter password (attempt 3/3): secret123
Access Granted!

Expected Output (all wrong):
Enter password (attempt 1/3): wrong
Wrong password!
Enter password (attempt 2/3): wrong
Wrong password!
Enter password (attempt 3/3): wrong
Wrong password!
Access Denied! Too many wrong attempts.
#include <stdio.h>
#include <string.h>

int main()
{
    char password[20] = "secret123";   // Fixed password
    char input[50];
    int attempt = 1;

    while(attempt <= 3)
    {
        printf("Enter password (attempt %d/3): ", attempt);
        fgets(input, sizeof(input), stdin);

        // Remove newline added by fgets
        input[strlen(input) - 1] = '\0';

        if(strcmp(input, password) == 0)
        {
            printf("Access Granted!\n");
            return 0;   // Stop program if correct
        }
        else
        {
            printf("Wrong password!\n");
        }

        attempt++;
    }

    printf("Access Denied! Too many wrong attempts.\n");

    return 0;
}
