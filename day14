1)Find first non-repeating character

#include <stdio.h>
#include <string.h>

int main()
{
    char str[20];
    int i,j,count;

    printf("enter a string\n");
    fgets(str, sizeof(str),stdin);
    int length=strlen(str);
    for(i=0;i<length;i++){
            count=0;

        for(j=0;j<length;j++){
                if(str[i]==str[j]){
            count++;

        }
        }
         if(count == 1 && str[i] != '\n'){


        printf("first non repeting character is=%c\n",str[i]);
         }
         }

    return 0;
}
